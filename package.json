{
  "name": "cocreate-desktop",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "concurrently \"npm:dev:site\" \"npm:dev:electron\"",
    "dev:overlay": "vite --config vite.overlay.config.ts",
    "dev:electron": "wait-on tcp:5173 && ELECTRON_RENDERER_URL=http://localhost:5173 electron electron/main.mjs",
    "dev:site": "vite",
    "build": "npm run build:site && npm run build:overlay",
    "build:site": "vite build",
    "build:overlay": "vite build --config vite.overlay.config.ts",
    "dist:mac": "npm run build && electron-builder --mac dmg zip",
    "start": "electron electron/main.mjs"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "lucide-react": "^0.542.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.0",
    "electron": "^31.7.7",
    "electron-builder": "^26.0.12",
    "typescript": "^5.8.3",
    "vite": "^5.4.19",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.cocreate.desktop",
    "productName": "CoCreate",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "overlay-dist/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    }
  }
}
